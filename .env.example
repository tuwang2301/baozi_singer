# Discord Bot Token (From Discord Developer Portal -> Bot -> Token)
DISCORD_TOKEN=your_bot_token_here

# Client ID (From Discord Developer Portal -> General Information -> Application ID)
CLIENT_ID=your_client_id_here

# Guild ID (For development slash command testing, or server-specific registration)
GUILD_ID=your_guild_id_here

# YouTube Cookies (Required to prevent 403 Forbidden streaming errors)
# Export your cookies in Netscape/JSON format using a browser extension and paste the raw cookie string here
YOUTUBE_COOKIE=your_youtube_cookie_here

